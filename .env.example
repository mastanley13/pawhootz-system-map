# Core GHL API access used by the refresh script
GHL_LOCATION_ID=your_location_id_here
GHL_API_TOKEN=replace_with_a_scoped_token

# Optional local portal access for screenshot capture
CLIENT_PORTAL_URL=http://127.0.0.1:5000
CLIENT_PORTAL_EMAIL=demo-client@example.com
CLIENT_PORTAL_PASSWORD=replace_with_temp_password

STAFF_PORTAL_URL=http://127.0.0.1:4175
STAFF_PORTAL_EMAIL=demo-staff@example.com
STAFF_PORTAL_PASSWORD=replace_with_temp_password
STAFF_PORTAL_PRIMARY_ROLE=frontdesk
STAFF_PORTAL_SECONDARY_ROLE=groomer

# Optional GHL UI access for browser-based screenshots
GHL_UI_URL=https://app.gohighlevel.com/
GHL_UI_EMAIL=demo-ghl@example.com
GHL_UI_PASSWORD=replace_with_temp_password
GHL_UI_LOCATION_NAME=PawHootz
